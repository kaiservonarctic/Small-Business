<section id="statutes" class="section section--alt">
  <div class="container">
    <h2 class="section-heading">{{ statutes.heading }}</h2>
    <p class="section-subtitle">{{ statutes.subtitle }}</p>

    {% if statutes.intro %}
    <div class="intro-card">
      <h3>{{ statutes.intro.title }}</h3>
      <p>{{ statutes.intro.body | md | safe }}</p>
    </div>
    {% endif %}

    {% for topic in statutes.topics %}
    <details class="accordion">
      <summary class="accordion-header">{{ topic.title }}</summary>
      <div class="accordion-body">
        {% for p in topic.paragraphs %}
        <p>{{ p | md | safe }}</p>
        {% endfor %}
      </div>
    </details>
    {% endfor %}
  </div>
</section>
