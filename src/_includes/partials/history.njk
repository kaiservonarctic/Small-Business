<section id="history" class="section">
  <div class="container">
    <h2 class="section-heading">{{ history.heading }}</h2>
    <p class="section-subtitle">{{ history.subtitle }}</p>

    <div class="timeline">
      {% for event in history.timeline %}
      <div class="timeline-item">
        <div class="timeline-marker {{ event.color | statusClass }}"></div>
        <div class="timeline-content">
          <div class="timeline-date">{{ event.date }}</div>
          <span class="badge badge--small {{ event.color | statusClass }}">{{ event.badge }}</span>
          <p>{{ event.event | md | safe }}</p>
        </div>
      </div>
      {% endfor %}
    </div>

    {% for topic in history.topics %}
    <details class="accordion">
      <summary class="accordion-header">{{ topic.title }}</summary>
      <div class="accordion-body">
        {% for p in topic.paragraphs %}
        <p>{{ p | md | safe }}</p>
        {% endfor %}
      </div>
    </details>
    {% endfor %}
  </div>
</section>
