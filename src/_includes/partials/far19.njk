<section id="far19" class="section section--alt">
  <div class="container">
    <h2 class="section-heading">{{ far19.heading }}</h2>
    <p class="section-subtitle">{{ far19.subtitle }}</p>

    {% if far19.alert %}
    <div class="alert">
      <strong>{{ far19.alert.title }}</strong>
      <p>{{ far19.alert.body | md | safe }}</p>
    </div>
    {% endif %}

    {% if far19.highlights %}
    <div class="highlights-grid">
      {% for h in far19.highlights %}
      <div class="highlight-card">
        <h3>{{ h.title }}</h3>
        <p>{{ h.body | md | safe }}</p>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% for detail in far19.details %}
    <details class="accordion">
      <summary class="accordion-header">{{ detail.title }}</summary>
      <div class="accordion-body">
        {% for p in detail.paragraphs %}
        <p>{{ p | md | safe }}</p>
        {% endfor %}
      </div>
    </details>
    {% endfor %}
  </div>
</section>
